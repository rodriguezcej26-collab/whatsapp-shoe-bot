# =============================================
# WhatsApp Shoe Bot - Variables de Entorno
# =============================================
# Copia este archivo como .env y llena los valores

# --- WhatsApp (Meta) ---
WHATSAPP_ACCESS_TOKEN=tu_token_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui
WHATSAPP_VERIFY_TOKEN=mi_token_secreto_personalizado

# --- Google Sheets ---
GOOGLE_CREDENTIALS_PATH=credentials/google_service_account.json
GOOGLE_SHEET_NAME=Inventario Calzado
GOOGLE_WORKSHEET_NAME=inventario

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=tu_api_key_aqui
